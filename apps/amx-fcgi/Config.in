config PACKAGE_amx-fcgi
    tristate
    select SAH_AMX_FCGI

if PACKAGE_amx-fcgi

menu "Select amx-fcgi build options"
    depends on PACKAGE_amx-fcgi

config SAH_AMX_FCGI
    bool "Build Ambiorix Fast CGI"
    default y

config SAH_AMX_FCGI_START_ORDER
    int "Start up order for the amx-fcgi plugin"
    default 85

config SAH_AMX_FCGI_STOP_ORDER
    int "Shutdown order for the amx-fcgi plugin"
    default 10

endmenu

endif
